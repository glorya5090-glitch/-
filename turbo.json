{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".next/**"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^build",
        "^typecheck"
      ],
      "outputs": []
    },
    "check": {
      "dependsOn": [
        "^check",
        "typecheck"
      ],
      "outputs": []
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ],
      "outputs": []
    },
    "test:unit": {
      "dependsOn": [
        "build",
        "^build",
        "^test:unit"
      ],
      "outputs": [
        "coverage/**"
      ]
    }
  }
}
