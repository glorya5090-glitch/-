{
  "name": "@worldlibertyfinancial/agent-cache",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./src/client/index.ts",
      "import": "./src/client/index.ts",
      "require": "./dist/client/index.cjs"
    },
    "./errors": {
      "types": "./src/errors/index.ts",
      "import": "./src/errors/index.ts",
      "require": "./dist/errors/index.cjs"
    },
    "./service": {
      "types": "./src/service/index.ts",
      "import": "./src/service/index.ts",
      "require": "./dist/service/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf .turbo node_modules dist coverage junit",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run typecheck"
  },
  "types": "./src/index.ts",
  "dependencies": {
    "ioredis": "^5.7.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.0",
    "vitest": "^3.2.4"
  }
}
