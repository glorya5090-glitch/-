{
  "name": "@worldlibertyfinancial/agent-ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "description": "Shared UI components and Tailwind configuration for AgentPay approval surfaces",
  "exports": {
    "./globals.css": "./src/globals.css",
    "./tailwind": {
      "types": "./src/tailwind.ts",
      "import": "./src/tailwind.ts",
      "default": "./src/tailwind.ts"
    },
    "./utils/cn": {
      "types": "./src/utils/cn.ts",
      "import": "./src/utils/cn.ts"
    },
    "./badge": {
      "types": "./src/components/badge.tsx",
      "import": "./src/components/badge.tsx"
    },
    "./button": {
      "types": "./src/components/button.tsx",
      "import": "./src/components/button.tsx"
    },
    "./card": {
      "types": "./src/components/card.tsx",
      "import": "./src/components/card.tsx"
    },
    "./input": {
      "types": "./src/components/input.tsx",
      "import": "./src/components/input.tsx"
    },
    "./label": {
      "types": "./src/components/label.tsx",
      "import": "./src/components/label.tsx"
    },
    "./separator": {
      "types": "./src/components/separator.tsx",
      "import": "./src/components/separator.tsx"
    },
    "./textarea": {
      "types": "./src/components/textarea.tsx",
      "import": "./src/components/textarea.tsx"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run typecheck"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.0"
  }
}
