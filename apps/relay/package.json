{
  "name": "@worldlibertyfinancial/agent-relay",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf .turbo node_modules dist coverage junit",
    "deploy:development": "node ../../scripts/unsupported-release-surface.mjs \"Relay deployment\"",
    "deploy:local": "node ../../scripts/unsupported-release-surface.mjs \"Relay deployment\"",
    "deploy:production": "node ../../scripts/unsupported-release-surface.mjs \"Relay deployment\"",
    "dev": "node ../../scripts/unsupported-release-surface.mjs \"Relay local development\"",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "start": "node ../../scripts/unsupported-release-surface.mjs \"Relay runtime\"",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run typecheck"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "@hono/trpc-server": "^0.4.0",
    "@trpc/server": "^11.7.1",
    "@worldlibertyfinancial/agent-cache": "workspace:*",
    "hono": "^4.9.6",
    "superjson": "^2.2.5",
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.152",
    "@types/node": "^24.0.0",
    "serverless": "^4.22.0",
    "serverless-esbuild": "^1.55.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.4"
  }
}
